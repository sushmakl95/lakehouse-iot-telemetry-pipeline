# Copy to .env (gitignored) and fill in. NEVER commit real values.

# Databricks
DATABRICKS_HOST=https://adb-XXXXX.cloud.databricks.com
DATABRICKS_TOKEN=dapi_YOUR_TOKEN_HERE

# AWS (for local Terraform runs)
AWS_PROFILE=mensa
AWS_REGION=ap-south-1

# Pipeline env selector
PIPELINE_ENV=local

# S3 paths (prod / staging only — local config hardcodes paths)
LANDING_BUCKET=s3://iot-telemetry-landing-dev
LAKEHOUSE_BUCKET=s3://iot-telemetry-lakehouse-dev
